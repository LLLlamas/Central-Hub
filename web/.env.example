# Backend selector. Defaults to `local` (localStorage + IndexedDB, no login).
# Set to `supabase` only when the two VITE_SUPABASE_* keys below are filled in.
VITE_BACKEND=local

# Supabase project config — Project Settings → API → Project URL + anon key.
# Copy this file to .env.local and fill in. The anon key is safe to expose in
# the browser — Row Level Security policies are the actual guard.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
